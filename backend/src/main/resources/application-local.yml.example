spring:
  datasource:
    url: jdbc:mysql://localhost:3306/resume_manage?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&useSSL=false
    username: root
    password: CHANGE_ME

  security:
    oauth2:
      client:
        registration:
          google:
            client-id: YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
            client-secret: YOUR_GOOGLE_CLIENT_SECRET
            scope:
              - email
              - profile
              - openid

app:
  upload:
    root-path: ./uploads
  security:
    jwt:
      # 최소 32자 이상, 운영 환경에서는 환경변수로 주입
      secret: local-dev-jwt-secret-change-me-at-least-32-characters-long-abcdef
      expiration-seconds: 86400
    oauth2:
      frontend-redirect-url: http://localhost:5173/oauth-callback
  # Web Push (VAPID) — `npx web-push generate-vapid-keys` 로 발급 후 붙여넣기
  web-push:
    public-key: YOUR_VAPID_PUBLIC_KEY
    private-key: YOUR_VAPID_PRIVATE_KEY
    subject: "mailto:you@example.com"
  # AI 교차검증 요약 — 3 모델 API 키
  # 키가 비어있으면 /api/ai/career-summary 는 503 로 응답하고 다른 기능은 정상 동작
  ai:
    anthropic:
      api-key: YOUR_ANTHROPIC_API_KEY
    openai:
      api-key: YOUR_OPENAI_API_KEY
    google:
      api-key: YOUR_GOOGLE_API_KEY
