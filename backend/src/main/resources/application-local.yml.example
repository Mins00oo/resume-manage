spring:
  datasource:
    url: jdbc:mysql://localhost:3306/resume_manage?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true&useSSL=false
    username: root
    password: CHANGE_ME

  security:
    oauth2:
      client:
        registration:
          google:
            client-id: YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
            client-secret: YOUR_GOOGLE_CLIENT_SECRET
            scope:
              - email
              - profile
              - openid

app:
  upload:
    root-path: ./uploads
  security:
    jwt:
      # 최소 32자 이상, 운영 환경에서는 환경변수로 주입
      secret: local-dev-jwt-secret-change-me-at-least-32-characters-long-abcdef
      expiration-seconds: 86400
    oauth2:
      frontend-redirect-url: http://localhost:5173/oauth-callback
